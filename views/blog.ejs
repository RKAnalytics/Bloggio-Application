<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./Partials/head') %>
    <link rel="stylesheet" href="/css/styles.css">
    <title>Bloggio</title>
</head>
<body>
    <%- include('./Partials/navbar') %>
    <div class="container mt-3">
        <h1><%= blog.title %></h1>
        <img src="<%= blog.coverImageUrl %>" alt="" width="600px">
        <pre><%= blog.body %></pre>
    </div>
    <div class="container mt-4">
        <img src="<%= blog.createdBy.profilePicUrl %>" alt="" width="50px"><%= blog.createdBy.name %>
         <span>
      • <%= blog.createdAt ? new Date(blog.createdAt).toLocaleString('en-US', { timeZone: 'Asia/Karachi' }) : '' %>
    </span>
    </div>
    
    <div class="container mt-3">
        <h3>Comments (<%= comments.length %>)</h3>
        <% if (locals.user) { %>
                <form action="/blog/comment/<%= blog._id %>" method="post">
        <input
          type="text"
          name="content"
          class="form-control"
          id="exampleInputEmail1"
          aria-describedby="emailHelp"
        />
        <button type="submit" class="btn btn-primary" style="margin: 12px">
          Post
        </button>
    </form>

    <% } %>
    <%  if(!locals.user) { %>
        <h6>Create an Account / SignIn to Comment </h6>
        <% } %>
<div class="mt-3">
  <% comments.forEach(comment => { %>
    <div class="comment">
      <div class="comment-header">
        <img src="<%= comment.createdBy.profilePicUrl %>" alt="" width="30px">
        <span class="comment-author"><%= comment.createdBy.name %></span>
        <span class="comment-date"><%= comment.createdAt ? new Date(comment.createdAt).toLocaleString('en-US', { timeZone: 'Asia/Karachi' }) : '' %></span>
      </div>
      <pre class="comment-body"><%= comment.content %></pre>
    </div>
  <% }) %>
</div>
    <%- include('./Partials/script') %>
</body>
</html>